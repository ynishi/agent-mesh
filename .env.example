# agent-mesh-server configuration
# Copy to .env and fill in values.

# Listen address (default: 0.0.0.0:8080)
# LISTEN=0.0.0.0:8080

# SQLite database path (default: mesh.db, or /data/mesh.db in Docker)
# DB_PATH=mesh.db

# OAuth provider for login (optional)
# OAUTH_PROVIDER=github
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
